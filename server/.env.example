# SRM Academia Backend — Environment Variables
# Copy this file to .env and fill in values

# Optional: Pre-configured CSRF token and session cookies (auto-fetched if empty)
SRM_CSRF_TOKEN=
SRM_SESSION_COOKIES=

# Server port (default: 3000)
PORT=3000

# Thought of the day generation (Mistral)
MISTRAL_API_KEY=
# Optional overrides:
# THOUGHT_OF_DAY_MISTRAL_API_KEY=
# THOUGHT_OF_DAY_MISTRAL_MODEL=mistral-small-latest
# THOUGHT_OF_DAY_TIMEZONE=Asia/Kolkata

# Supabase (OD persistence)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Push Notifications (VAPID keys)
# Generate these using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Frontend URL for CORS (production only)
FRONTEND_URL=https://nexus-srm-academia-portal.vercel.app

# Cron Jobs Secret (for Vercel Cron authentication)
# Generate a random string: openssl rand -base64 32
CRON_SECRET=
