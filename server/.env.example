# SRM Academia Backend — Environment Variables
# Copy this file to .env and fill in values

# Optional: Pre-configured CSRF token and session cookies (auto-fetched if empty)
SRM_CSRF_TOKEN=
SRM_SESSION_COOKIES=

# Server port (default: 3000)
PORT=3000

# Thought of the day generation (Mistral)
MISTRAL_API_KEY=
# Optional overrides:
# THOUGHT_OF_DAY_MISTRAL_API_KEY=
# THOUGHT_OF_DAY_MISTRAL_MODEL=mistral-small-latest
# THOUGHT_OF_DAY_TIMEZONE=Asia/Kolkata

# Supabase (OD persistence)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
