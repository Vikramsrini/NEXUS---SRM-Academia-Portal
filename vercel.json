{
  "crons": [
    {
      "path": "/api/cron/quote",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/wordle",
      "schedule": "31 18 * * *"
    },
    {
      "path": "/api/cron/day-order",
      "schedule": "30 14 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/|assets/|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
